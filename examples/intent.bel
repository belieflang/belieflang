let threshold = 0.7

belief intent {
  book_flight: 0.82
  book_hotel: 0.12
  unknown: 0.06
}

belief user {
  budget_sensitive: 0.91
  prefers_direct: 0.84
}

let flights = call search_flights()

when confidence(intent.book_flight) > threshold:
  call rank_flights()

when flights.count > 0:
  ask_user("I found flight options.")
